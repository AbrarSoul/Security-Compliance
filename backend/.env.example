# Application
APP_NAME=Security Compliance API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://compliance:compliance@localhost:5432/compliance

# JWT
JWT_SECRET_KEY=change-me-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# File storage
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_FILE_EXTENSIONS=csv,json,txt
METADATA_PREVIEW_ROWS=50

# Compliance scanner
SCAN_MAX_SAMPLE_ROWS=1000
SCAN_MATCH_THRESHOLD=0.05

# Compliance scoring
SCORE_SEVERITY_WEIGHTS=low:5,medium:15,high:25,critical:40
SCORE_FINDING_TYPE_WEIGHTS=email:10,phone:10,password:35,api_key:40,name:5,sensitive_field:8
SCORE_COMPLIANT_MAX=30
SCORE_RISKY_MAX=60
SCORE_MAX=100
SCORE_DENSITY_MULTIPLIER=10
SCORE_CLASSIFICATION_RESTRICTED_MIN=70
SCORE_CLASSIFICATION_CONFIDENTIAL_MIN=40
SCORE_CLASSIFICATION_INTERNAL_MIN=15
SCORE_CRITICAL_ESCALATION_MATCH_RATE=0.01
SCORE_FORCE_NON_COMPLIANT_ON_CRITICAL=true

# GPT-Lab (TUNI) — model registry sync
GPTLAB_API_KEY=sk-ollama-gptlab-6cc87c9bd38b24aca0fe77f0c9c4d68d
GPTLAB_API_BASE=https://gptlab.rd.tuni.fi/GPT-Lab/resources/GPU-farmi-004/v1
